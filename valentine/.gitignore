# Valentine's Day Website - .gitignore

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/
*.min.css
*.min.js

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment
.env
.env.local
.env.*.local

# Docker
docker/*.log

# Assets (large files - consider Git LFS for photos/videos)
# assets/photos/*.jpg
# assets/photos/*.webp
# assets/videos/*.mp4
# assets/music/*.mp3

# Test/coverage
coverage/
.nyc_output/

# Misc
*.tmp
*.temp
.cache/